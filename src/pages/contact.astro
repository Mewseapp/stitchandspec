---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Contact | Stitch & Spec"
  description="Contact Stitch & Spec with reader questions, affiliate partnership inquiries, and corrections to published machine research."
>
  <article class="trust-page contact-page">
    <header class="trust-hero compact">
      <p class="publication-kicker">Contact Stitch &amp; Spec</p>
      <h1>Questions, corrections, and partnership inquiries</h1>
      <p class="lead">
        Stitch &amp; Spec welcomes reader questions, corrections to published research, and affiliate partnership inquiries from relevant sewing, embroidery, quilting, and craft retailers.
      </p>
    </header>

    <section class="contact-card" aria-labelledby="email-heading">
      <div>
        <p class="section-label">Email</p>
        <h2 id="email-heading">Reach the editorial team</h2>
        <p>
          Send a note to the address below. For corrections, please include the page URL and the source or specification that should be reviewed.
        </p>
      </div>
      <a class="contact-email" href="mailto:contact@stitchandspec.com">contact@stitchandspec.com</a>
    </section>
  </article>
</BaseLayout>
