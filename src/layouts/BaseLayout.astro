---
import '../styles/global.css';
const {
  title,
  description = 'Neutral, citation-ready sewing and embroidery machine research.',
  jsonLd = [],
  ogType = 'website'
} = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site || 'https://stitchandspec.com').toString();
const schemaBlocks = Array.isArray(jsonLd) ? jsonLd.filter(Boolean) : [jsonLd].filter(Boolean);
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="deployment-check" content="steph-phase-fixes-2026-06-25-v10" />
    <link rel="canonical" href={canonical} />
    <meta property="og:site_name" content="Stitch &amp; Spec" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonical} />
    {schemaBlocks.map((schema) => <script type="application/ld+json" set:html={JSON.stringify(schema)} />)}
  </head>
  <body>
    <header class="site-header">
      <a href="/" class="brand" aria-label="Stitch and Spec home">
        <span class="brand-name">Stitch <em>&amp;</em> Spec</span>
      </a>
      <nav aria-label="Primary navigation">
        <a href="/research-graph/">Research map</a>
        <a href="/research-graph/#product-comparisons">Comparisons</a>
        <a href="/research-graph/#guides">Guides</a>
        <a href="/editorial-policy/">Editorial policy</a>
        <a href="/about/">About</a>
        <a href="/contact/">Contact</a>
      </nav>
    </header>
    <main><slot /></main>
    <footer>
      <div class="footer-inner">
        <div>
          <strong>Stitch &amp; Spec</strong>
          <p>Project-first sewing and embroidery machine research for buyers who want clarity before spending real money.</p>
        </div>
        <div class="footer-links">
          <a href="/about/">About</a>
          <a href="/contact/">Contact</a>
          <a href="/privacy/">Privacy policy</a>
          <a href="/affiliate-disclosure/">Affiliate disclosure</a>
          <a href="/editorial-policy/">Editorial policy</a>
          <a href="/research-graph/">Research map</a>
        </div>
      </div>
    </footer>
  </body>
</html>
