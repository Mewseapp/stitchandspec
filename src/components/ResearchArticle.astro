---
import AffiliateProductList from './AffiliateProductList.astro';
import { products } from '../data/affiliates';
import { researchPages } from '../data/pages';

const { page } = Astro.props;
const relatedLinkTargetsByRoute = {
  '/best-sewing-embroidery-machine-for-beginners/': '/brother-se700-vs-se2000/',
  '/embroidery-hoop-size-explained/': '/brother-se700-vs-se2000/',
  '/brother-se700-vs-se2000/': '/best-sewing-embroidery-machine-for-beginners/',
  '/sewing-machine-for-denim-and-canvas/': '/industrial-vs-domestic-sewing-machine/',
  '/embroidery-machine-for-small-business/': '/embroidery-machine-for-hats/',
  '/what-supplies-do-you-need-for-machine-embroidery/': '/embroidery-stabilizer-guide/',
  '/embroidery-machine-for-shirts/': '/embroidery-hoop-size-explained/',
  '/embroidery-machine-for-hats/': '/embroidery-machine-for-small-business/',
  '/sewing-machine-for-quilting/': '/longarm-vs-domestic-quilting-machine/',
  '/longarm-vs-domestic-quilting-machine/': '/sewing-machine-for-quilting/',
  '/serger-vs-sewing-machine/': '/coverstitch-vs-serger/',
  '/coverstitch-vs-serger/': '/serger-vs-sewing-machine/',
  '/industrial-vs-domestic-sewing-machine/': '/sewing-machine-for-denim-and-canvas/',
  '/sewing-machine-needle-sizes/': '/sewing-machine-for-denim-and-canvas/',
  '/embroidery-stabilizer-guide/': '/what-supplies-do-you-need-for-machine-embroidery/',
  '/embroidery-thread-types/': '/what-supplies-do-you-need-for-machine-embroidery/',
  '/embroidery-software-for-beginners/': '/embroidery-file-formats/',
  '/embroidery-file-formats/': '/embroidery-software-for-beginners/',
  '/best-sewing-machine-for-bag-making/': '/industrial-vs-domestic-sewing-machine/',
  '/best-machine-for-cosplay/': '/serger-vs-sewing-machine/',
  '/sewing-machine-for-alterations/': '/automatic-vs-computerized-sewing-machine/',
  '/automatic-vs-computerized-sewing-machine/': '/sewing-machine-for-alterations/',
  '/sewing-machine-maintenance/': '/sewing-machine-warranty-and-service/',
  '/used-vs-new-sewing-machine/': '/sewing-machine-warranty-and-service/',
  '/sewing-machine-warranty-and-service/': '/used-vs-new-sewing-machine/'
};
const routeForSlug = (slug) => `/${slug}/`;
const currentRoute = routeForSlug(page.slug);
const relatedTargetRoute = relatedLinkTargetsByRoute[currentRoute];
const existingInternalRoutes = new Set(page.nextQuestions.map(routeForSlug));
const relatedTargetPage = relatedTargetRoute
  ? researchPages.find((item) => routeForSlug(item.slug) === relatedTargetRoute)
  : undefined;
const relatedLink = relatedTargetPage && !existingInternalRoutes.has(relatedTargetRoute)
  ? {
      label: relatedTargetPage.intent === 'compare' ? 'Related comparison' : 'Related guide',
      route: relatedTargetRoute,
      title: relatedTargetPage.title
    }
  : null;
const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: page.faq.map((item) => ({ '@type': 'Question', name: item.q, acceptedAnswer: { '@type': 'Answer', text: item.a } }))
};
const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: page.title,
  description: page.bluf,
  dateModified: page.lastUpdated,
  about: page.buyerQuestion,
  author: { '@type': 'Organization', name: 'Stitch & Spec' },
  publisher: { '@type': 'Organization', name: 'Stitch & Spec' },
  mainEntityOfPage: Astro.url.href
};
const comparisonSchema = page.intent === 'compare' && page.table ? {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: `${page.title} comparison factors`,
  itemListOrder: 'https://schema.org/ItemListOrderAscending',
  numberOfItems: page.table.rows.length,
  itemListElement: page.table.rows.map((row, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    item: {
      '@type': 'Thing',
      name: row[0],
      description: page.table.columns.map((column, columnIndex) => `${column}: ${row[columnIndex]}`).join('; ')
    }
  }))
} : null;
const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: new URL('/', Astro.site || 'https://stitchandspec.com').toString() },
    { '@type': 'ListItem', position: 2, name: 'Research map', item: new URL('/research-graph/', Astro.site || 'https://stitchandspec.com').toString() },
    { '@type': 'ListItem', position: 3, name: page.title, item: Astro.url.href }
  ]
};
const normalizeProductText = (value = '') => value.toLowerCase().replace(/[^a-z0-9]+/g, '');
const sourceLabels = normalizeProductText(page.sources.map((source) => source.label).join(' '));
const affiliateProducts = products.filter((product) => {
  const url = product.affiliateUrlByMerchant['sewing-machines-plus'];
  if (!url) return false;
  const candidates = (product.facts.linkKey ? [product.facts.linkKey] : [product.name, product.facts.model])
    .map(normalizeProductText)
    .filter((candidate) => candidate.length > 2);
  return candidates.some((candidate) => sourceLabels.includes(candidate));
});
const visualByCluster = {
  'beginner-buying': 'Machine context',
  'embroidery-basics': 'Hoop and stabilizer notes',
  'product-comparisons': 'Side-by-side comparison',
  'materials': 'Fabric stack test',
  'business': 'Batch workflow',
  'projects': 'Finished project reference',
  'quilting': 'Throat-space reference',
  'machine-types': 'Machine class reference',
  'troubleshooting': 'Needle and stitch detail',
  'software': 'Screen and file workflow',
  'buying': 'Inspection checklist'
};
const visualLabel = visualByCluster[page.cluster] || 'Machine research reference';
---
<script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
<script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
{comparisonSchema && <script type="application/ld+json" set:html={JSON.stringify(comparisonSchema)} />}
<script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
<article class="research-page">
  <header class="article-hero">
    <div class="article-title-block">
      <p class="article-meta">{page.cluster.replaceAll('-', ' ')} · Last updated {page.lastUpdated}</p>
      <h1>{page.title}</h1>
      <section class="bluf" aria-label="Direct answer">
        <strong>Bottom line</strong>
        <p>{page.bluf}</p>
      </section>
    </div>
    <figure class="image-slot article-image-slot" aria-label={visualLabel}>
      <div class="slot-stage compact-stage">
        <span class="slot-badge">{visualLabel}</span>
        <span class="machine-block machine-arm"></span>
        <span class="machine-block machine-bed"></span>
        <span class="machine-block hoop-window"></span>
        <span class="stitch-path"></span>
      </div>
    </figure>
  </header>

  {page.recommendation && (
    <section class="recommendation" aria-label="Recommendation">
      <span class="section-label">Practical recommendation</span>
      <p>{page.recommendation}</p>
      <div class="cta-row">
        <a class="button secondary" href="/research-graph/">See related guides</a>
      </div>
    </section>
  )}

  <section class="content-panel question-card">
    <h2>What you're deciding</h2>
    <p>{page.buyerQuestion}</p>
  </section>

  <AffiliateProductList products={affiliateProducts} />

  {page.table ? (
    <section class="content-panel table-card">
      <h2>Decision table</h2>
      <div class="table-wrap">
        <table>
          <thead><tr>{page.table.columns.map((column) => <th>{column}</th>)}</tr></thead>
          <tbody>{page.table.rows.map((row) => <tr>{row.map((cell) => <td>{cell}</td>)}</tr>)}</tbody>
        </table>
      </div>
    </section>
  ) : (
    <section class="content-panel table-card">
      <h2>Comparison points</h2>
      <div class="table-wrap">
        <table>
          <thead><tr><th>Factor</th><th>Why it matters</th></tr></thead>
          <tbody>
            {(page.comparisons?.length ? page.comparisons : ['price', 'project fit', 'service access']).map((factor) => (
              <tr><td>{factor}</td><td>Use this factor to separate a useful machine choice from a spec-sheet-only choice.</td></tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>
  )}

  <div class="article-body-grid">
    {page.sections?.map((section, index) => (
      <section class="article-section" style={index === 0 ? 'grid-template-columns: 1fr;' : undefined}>
        <div>
          <h2>{section.heading}</h2>
          <p>{section.body}</p>
          {section.bullets && <ul>{section.bullets.map((bullet) => <li>{bullet}</li>)}</ul>}
        </div>
      </section>
    ))}
  </div>

  <section class="content-panel next-card">
    <h2>What should you ask next?</h2>
    <div class="next-grid">
      {page.nextQuestions.map((slug) => <a class="next-link" href={`/${slug}/`}>{slug.replaceAll('-', ' ')}</a>)}
    </div>
  </section>

  {relatedLink && (
    <section class="content-panel related-card" aria-label={relatedLink.label}>
      <span class="section-label">{relatedLink.label}</span>
      <p><a href={relatedLink.route}>{relatedLink.title}</a></p>
    </section>
  )}

  <section class="content-panel source-card">
    <h2>Sources used</h2>
    <ul>{page.sources.map((source) => <li><a href={source.url}>{source.label}</a></li>)}</ul>
  </section>

  <section class="content-panel faq-card">
    <h2>FAQ</h2>
    {page.faq.map((item) => <details><summary>{item.q}</summary><p>{item.a}</p></details>)}
  </section>
</article>
