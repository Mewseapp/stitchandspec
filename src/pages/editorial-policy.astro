---
import BaseLayout from '../layouts/BaseLayout.astro';
const siteUrl = Astro.site || 'https://stitchandspec.com';
const policyUrl = new URL('/editorial-policy/', siteUrl).toString();
const policyDescription = 'Editorial standards for sourced Stitch & Spec sewing and embroidery machine guidance.';
const policyJsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    name: 'Editorial policy',
    description: policyDescription,
    url: policyUrl,
    isPartOf: { '@type': 'WebSite', name: 'Stitch & Spec', url: new URL('/', siteUrl).toString() }
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: new URL('/', siteUrl).toString() },
      { '@type': 'ListItem', position: 2, name: 'Editorial policy', item: policyUrl }
    ]
  }
];
---
<BaseLayout title="Editorial Policy | Stitch & Spec" description={policyDescription} jsonLd={policyJsonLd}>
  <article class="policy-page">
    <header class="page-hero compact">
      <p class="publication-kicker">Publication standards</p>
      <h1>Editorial policy</h1>
      <p class="lead">Stitch &amp; Spec prioritizes sourced machine guidance over product hype.</p>
    </header>
    <section class="policy-section">
      <h2>Editorial standards</h2>
      <ul>
        <li>Every research page starts with a direct bottom-line answer.</li>
        <li>Claims rely on manufacturer documentation, retailer specifications, manuals, or clearly labeled expert sources.</li>
        <li>Comparisons prioritize project fit, machine limits, serviceability, and upgrade risk.</li>
        <li>Affiliate relationships do not change recommendations or conclusions.</li>
        <li>Pages show a visible last-updated date and answer common buyer questions directly.</li>
      </ul>
    </section>
  </article>
</BaseLayout>
