---
import BaseLayout from '../layouts/BaseLayout.astro';
import { researchPages } from '../data/pages';
const byCluster = Object.groupBy(researchPages, (page) => page.cluster);
---
<BaseLayout title="Research Graph | Stitch & Spec">
  <h1>Research graph</h1>
  <p class="bluf"><strong>BLUF:</strong> The first content cluster is a 25-page buyer-question graph. Every page links to the next practical question instead of ending at a dead affiliate CTA.</p>
  {Object.entries(byCluster).map(([cluster, pages]) => (
    <section>
      <h2>{cluster}</h2>
      <ul>{pages?.map((page) => <li><a href={`/${page.slug}/`}>{page.title}</a> — {page.buyerQuestion}</li>)}</ul>
    </section>
  ))}
</BaseLayout>
